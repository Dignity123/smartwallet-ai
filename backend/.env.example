# Copy to `.env` and fill in. Do not commit `.env` with real secrets.

# Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional override (default: gemini-2.0-flash). See models in Google AI Studio.
# GEMINI_MODEL=gemini-2.0-flash

# SQLite default; use postgres/mysql URL in production if needed
DATABASE_URL=sqlite:///./smartwallet.db

# Plaid (optional; mock data is used when USE_MOCK_DATA=true and nothing in DB)
USE_MOCK_DATA=true
PLAID_ENV=sandbox
PLAID_CLIENT_ID=
PLAID_SECRET=
# Webhook URL in Plaid Dashboard → this server POST /api/plaid/webhook
