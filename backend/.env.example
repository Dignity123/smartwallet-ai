# Copy to `.env` and fill in. Do not commit `.env` with real secrets.

# OpenAI
# Create an API key in your OpenAI dashboard and paste here.
OPENAI_API_KEY=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
OPENAI_MODEL=gpt-4o-mini

# SQLite default; use postgres/mysql URL in production if needed
DATABASE_URL=sqlite:///./smartwallet.db

# Auth
# JWT required for protected routes when true; set false to always use demo user id 1 (no tokens).
AUTH_ENABLED=true
# When true and no Bearer token, API uses demo user id 1 (matches Flutter builds without login).
ALLOW_ANONYMOUS_DEMO=true
# Change this in production.
JWT_SECRET=dev-only-change-me

# Plaid (optional; mock data is used when USE_MOCK_DATA=true and nothing in DB)
USE_MOCK_DATA=true
PLAID_ENV=sandbox
PLAID_CLIENT_ID=
PLAID_SECRET=
# Optional: default webhook used when creating link tokens (otherwise set in Plaid Dashboard)
# This server receives webhooks at: POST /api/plaid/webhook
PLAID_WEBHOOK_URL=
