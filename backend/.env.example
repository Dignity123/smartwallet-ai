# Copy to `.env` and fill in. Do not commit `.env` with real secrets.

# Required for AI features (impulse, subscriptions, recommendations)
ANTHROPIC_API_KEY=

# SQLite default; use postgres/mysql URL in production if needed
DATABASE_URL=sqlite:///./smartwallet.db

# Plaid (optional; mock data is used when USE_MOCK_DATA=true)
USE_MOCK_DATA=true
PLAID_CLIENT_ID=
PLAID_SECRET=
